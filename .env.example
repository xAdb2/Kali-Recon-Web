# ---------------------------------------------------------------------------
# KaliRecon Web — environment configuration
# Copy to .env (scripts/install.sh does this) and fill in secrets.
# NEVER commit a real .env. Do not expose this service publicly.
# ---------------------------------------------------------------------------

# --- Django core ---
# Generate with: python -c "import secrets;print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,web
DJANGO_TIME_ZONE=Asia/Taipei
# Set true only when serving behind HTTPS (not the plain SSH-tunnel default).
DJANGO_COOKIE_SECURE=false
LOG_LEVEL=INFO

# --- Web bind (host side) ---
# The web service binds to 127.0.0.1:${WEB_PORT}. Keep it on localhost.
WEB_PORT=8080

# --- PostgreSQL (internal only, not published to host) ---
POSTGRES_DB=kalirecon
POSTGRES_USER=kalirecon
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis / Celery (internal only) ---
REDIS_URL=redis://redis:6379/0
CELERY_WORKER_CONCURRENCY=1

# --- Scanner / Docker runner ---
SCANNER_IMAGE=kalirecon-scanner:local
WORKSPACE_VOLUME=kalirecon_workspaces
WORKSPACE_ROOT=/workspace
# Leave SCANNER_NETWORK empty for the default bridge (scanners need egress).
SCANNER_NETWORK=
SCANNER_CPU=1.0
SCANNER_MEMORY=1g
SCANNER_PIDS_LIMIT=256

# --- Limits ---
MAX_ACTIVE_TASKS=3
MAX_THREADS=20
MAX_RATE=200
STEP_TIMEOUT_DEFAULT=900
TASK_TIMEOUT_DEFAULT=3600

# --- Expert custom command mode (Section 8.8) ---
# Enable only for the trusted localhost / SSH-tunnel deployment.
# Set false for any production-style deployment.
ENABLE_EXPERT_COMMANDS=true

# --- Nuclei templates ---
NUCLEI_TEMPLATE_VERSION=bundled

# --- Initial admin (used by scripts/install.sh / create_admin) ---
# Leave ADMIN_PASSWORD empty to auto-generate a one-time password.
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.local
ADMIN_PASSWORD=

# --- Prebuilt GHCR images (compose.prebuilt.yml) ---
# Derived from the git remote by install.sh when possible. In prebuilt mode set
# SCANNER_IMAGE (above) to the GHCR scanner ref so the worker pulls it.
APP_IMAGE=kalirecon-app:local
# For prebuilt: APP_IMAGE=ghcr.io/OWNER/REPO-app:latest
#               SCANNER_IMAGE=ghcr.io/OWNER/REPO-scanner:latest
